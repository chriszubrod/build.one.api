# =============================================================================
# infra/.secrets.env — required secret values for provision.sh  (TEMPLATE)
# =============================================================================
# Copy to infra/.secrets.env (GITIGNORED) and fill in real values.
# provision.sh sources this file; values are passed to `az ... appsettings set`.
# NEVER commit the filled-in copy. Long-term these should move to Key Vault
# references (@Microsoft.KeyVault(SecretUri=...)) — see infra/README.md.
# =============================================================================

# ---- Core API secrets -------------------------------------------------------
SECRET_KEY=
ENCRYPTION_KEY=                      # Fernet master key — protects QBO/MS tokens
OAUTH_STATE_SECRET=
DRAIN_SECRET=                        # shared with the scheduler Function App
SIGNUP_REGISTRATION_CODE=

# ---- Database ---------------------------------------------------------------
DB_PASSWORD=

# ---- Azure resource keys ----------------------------------------------------
AZURE_STORAGE_ACCOUNT_KEY=
AZURE_DOCUMENT_INTELLIGENCE_KEY=
DOCKER_REGISTRY_SERVER_PASSWORD=     # ACR admin password (`az acr credential show -n buildone`)

# ---- LLM provider -----------------------------------------------------------
ANTHROPIC_API_KEY=
# AZURE_OPENAI_API_KEY=              # only if the Azure embeddings path is still used

# ---- MCP server -------------------------------------------------------------
MCP_AUTH_TOKEN=                      # inbound bearer for the MCP HTTP server

# ---- Agent fleet credentials (username is config, password is secret) -------
SCOUT_AGENT_USERNAME=;          SCOUT_AGENT_PASSWORD=
SUB_COST_CODE_AGENT_USERNAME=;  SUB_COST_CODE_AGENT_PASSWORD=
COST_CODE_AGENT_USERNAME=;      COST_CODE_AGENT_PASSWORD=
CUSTOMER_AGENT_USERNAME=;       CUSTOMER_AGENT_PASSWORD=
PROJECT_AGENT_USERNAME=;        PROJECT_AGENT_PASSWORD=
VENDOR_AGENT_USERNAME=;         VENDOR_AGENT_PASSWORD=
BILL_AGENT_USERNAME=;           BILL_AGENT_PASSWORD=
BILL_CREDIT_AGENT_USERNAME=;    BILL_CREDIT_AGENT_PASSWORD=
EXPENSE_AGENT_USERNAME=;        EXPENSE_AGENT_PASSWORD=
INVOICE_AGENT_USERNAME=;        INVOICE_AGENT_PASSWORD=
EMAIL_AGENT_USERNAME=;          EMAIL_AGENT_PASSWORD=
CLAUDE_AGENT_USERNAME=;         CLAUDE_AGENT_PASSWORD=
TIME_TRACKING_AGENT_USERNAME=;  TIME_TRACKING_AGENT_PASSWORD=
