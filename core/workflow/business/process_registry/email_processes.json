{
  "_comment": "Email Process Registry — defines stage maps for inbound email document types. Each process type represents a category of email that arrives in the inbox, gets classified and extracted by the Email Agent, and hands off to the Entity Process Registry once a business entity is created.",
  "version": "1.0.0",
  "registry_type": "email",
  "processes": {

    "BILL_DOCUMENT": {
      "description": "An inbound email containing a vendor invoice or bill. Agent extracts, classifies, creates draft, and forwards to PM for approval.",
      "initial_stage": "RECEIVED",
      "entity_handoff": "BILL",
      "stages": [
        "RECEIVED",
        "EXTRACTING",
        "ENTITY_CREATED",
        "PENDING_APPROVAL",
        "APPROVAL_RECEIVED",
        "DISPUTED_RECEIVED",
        "REJECTED_RECEIVED",
        "ENTITY_UPDATED",
        "ENTITY_COMPLETED"
      ],
      "transitions": {
        "RECEIVED":           ["EXTRACTING"],
        "EXTRACTING":         ["ENTITY_CREATED"],
        "ENTITY_CREATED":     ["PENDING_APPROVAL"],
        "PENDING_APPROVAL":   ["APPROVAL_RECEIVED", "DISPUTED_RECEIVED", "REJECTED_RECEIVED"],
        "APPROVAL_RECEIVED":  ["ENTITY_UPDATED"],
        "DISPUTED_RECEIVED":  ["PENDING_APPROVAL"],
        "REJECTED_RECEIVED":  ["PENDING_APPROVAL"],
        "ENTITY_UPDATED":     ["ENTITY_COMPLETED"]
      },
      "requires_action_at": ["DISPUTED_RECEIVED", "REJECTED_RECEIVED"],
      "auto_advance_at":    ["RECEIVED", "EXTRACTING", "ENTITY_CREATED", "APPROVAL_RECEIVED"],
      "sla": {
        "PENDING_APPROVAL":  { "max_hours": 48, "on_breach": "SLA_BREACH" },
        "DISPUTED_RECEIVED": { "max_hours": 72, "on_breach": "SLA_BREACH" },
        "REJECTED_RECEIVED": { "max_hours": 72, "on_breach": "SLA_BREACH" }
      }
    },

    "BILL_CREDIT_DOCUMENT": {
      "description": "An inbound email containing a vendor credit note. Extraction creates a BillCredit entity with BillCreditLineItems.",
      "initial_stage": "RECEIVED",
      "entity_handoff": "BILL_CREDIT",
      "stages": [
        "RECEIVED",
        "EXTRACTING",
        "REVIEW_NEEDED",
        "APPROVED",
        "ENTITY_CREATED",
        "DISPUTED",
        "REJECTED",
        "CLOSED"
      ],
      "transitions": {
        "RECEIVED":       ["EXTRACTING"],
        "EXTRACTING":     ["REVIEW_NEEDED"],
        "REVIEW_NEEDED":  ["APPROVED", "DISPUTED", "REJECTED"],
        "APPROVED":       ["ENTITY_CREATED"],
        "ENTITY_CREATED": ["CLOSED"],
        "DISPUTED":       ["REVIEW_NEEDED", "REJECTED"],
        "REJECTED":       ["CLOSED"]
      },
      "requires_action_at": ["REVIEW_NEEDED", "DISPUTED", "REJECTED"],
      "auto_advance_at":    ["RECEIVED", "ENTITY_CREATED"],
      "sla": {
        "REVIEW_NEEDED": { "max_hours": 48, "on_breach": "SLA_BREACH" },
        "DISPUTED":      { "max_hours": 72, "on_breach": "SLA_BREACH" }
      }
    },

    "EXPENSE_DOCUMENT": {
      "description": "An inbound email containing an expense receipt or document. Extraction creates an Expense entity with ExpenseLineItems.",
      "initial_stage": "RECEIVED",
      "entity_handoff": "EXPENSE",
      "stages": [
        "RECEIVED",
        "EXTRACTING",
        "CATEGORIZING",
        "REVIEW_NEEDED",
        "APPROVED",
        "ENTITY_CREATED",
        "DISPUTED",
        "REJECTED",
        "CLOSED"
      ],
      "transitions": {
        "RECEIVED":       ["EXTRACTING"],
        "EXTRACTING":     ["CATEGORIZING"],
        "CATEGORIZING":   ["REVIEW_NEEDED"],
        "REVIEW_NEEDED":  ["APPROVED", "DISPUTED", "REJECTED"],
        "APPROVED":       ["ENTITY_CREATED"],
        "ENTITY_CREATED": ["CLOSED"],
        "DISPUTED":       ["REVIEW_NEEDED", "REJECTED"],
        "REJECTED":       ["CLOSED"]
      },
      "requires_action_at": ["REVIEW_NEEDED", "DISPUTED", "REJECTED"],
      "auto_advance_at":    ["RECEIVED", "ENTITY_CREATED"],
      "sla": {
        "REVIEW_NEEDED": { "max_hours": 48, "on_breach": "SLA_BREACH" },
        "DISPUTED":      { "max_hours": 72, "on_breach": "SLA_BREACH" }
      },
      "_note": "CATEGORIZING stage is unique to expenses — the Expense Categorization Agent assigns cost codes before owner review."
    },

    "EXPENSE_REFUND_DOCUMENT": {
      "description": "An inbound email containing an expense refund document. Rare but processed identically to an Expense. Extraction creates an ExpenseRefund entity.",
      "initial_stage": "RECEIVED",
      "entity_handoff": "EXPENSE_REFUND",
      "stages": [
        "RECEIVED",
        "EXTRACTING",
        "CATEGORIZING",
        "REVIEW_NEEDED",
        "APPROVED",
        "ENTITY_CREATED",
        "DISPUTED",
        "REJECTED",
        "CLOSED"
      ],
      "transitions": {
        "RECEIVED":       ["EXTRACTING"],
        "EXTRACTING":     ["CATEGORIZING"],
        "CATEGORIZING":   ["REVIEW_NEEDED"],
        "REVIEW_NEEDED":  ["APPROVED", "DISPUTED", "REJECTED"],
        "APPROVED":       ["ENTITY_CREATED"],
        "ENTITY_CREATED": ["CLOSED"],
        "DISPUTED":       ["REVIEW_NEEDED", "REJECTED"],
        "REJECTED":       ["CLOSED"]
      },
      "requires_action_at": ["REVIEW_NEEDED", "DISPUTED", "REJECTED"],
      "auto_advance_at":    ["RECEIVED", "ENTITY_CREATED"],
      "sla": {
        "REVIEW_NEEDED": { "max_hours": 48, "on_breach": "SLA_BREACH" },
        "DISPUTED":      { "max_hours": 72, "on_breach": "SLA_BREACH" }
      }
    }

  }
}
